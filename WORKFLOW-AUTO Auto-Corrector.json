              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 4096,\n  \"temperature\": 0,\n  \"system\": \"Tu es un expert n8n en mode auto-correction. Tu reçois un workflow n8n qui a planté et tu dois le corriger.\\n\\nRéponds UNIQUEMENT en JSON avec ce format :\\n{\\n  \\\"diagnosis\\\": \\\"Cause de l'erreur en 1 phrase\\\",\\n  \\\"fix\\\": \\\"Ce qui a été corrigé\\\",\\n  \\\"workflow\\\": { ... workflow n8n complet corrigé ... }\\n}\\n\\nRègles de correction :\\n- Ne change que ce qui est nécessaire pour corriger l'erreur.\\n- Conserve tous les autres nodes intacts.\\n- Le workflow corrigé doit avoir la même structure que l'original.\\n- errorWorkflow doit rester 'YOUR_N8N_URL/workflow/RaHgXr2IpKEIfpw1' dans les settings.\\n- Ne mets JAMAIS de texte hors du JSON.\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Tentative {{ $('Initialiser contexte').first().json.attempt }}/3\\nWorkflow : {{ $json.name }}\\nNode fautif : {{ $('Initialiser contexte').first().json.nodeName }}\\nErreur : {{ $('Initialiser contexte').first().json.errorMessage }}\\n\\nWorkflow actuel :\\n{{ JSON.stringify($json) }}\"\n  }]\n}",
        "options": {}
      },
      "id": "dc1099c1-6d19-4e76-b58f-dcf5548b66e8",
      "name": "Claude corrige",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        112,
        -96
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text.trim();\nlet parsed;\ntry {\n  let cleaned = raw.replace(/```json\\n?/gi,'').replace(/```\\n?/gi,'').trim();\n  let depth = 0, start = -1, end = -1;\n  for (let i = 0; i < cleaned.length; i++) {\n    if (cleaned[i] === '{') { if (depth === 0) start = i; depth++; }\n    else if (cleaned[i] === '}') { depth--; if (depth === 0) { end = i; break; } }\n  }\n  if (start === -1 || end === -1) throw new Error('No valid JSON object found');\n  parsed = JSON.parse(cleaned.substring(start, end + 1));\n} catch(err) {\n  return [{ json: { success: false, error: err.message } }];\n}\nconst workflowId = $('Initialiser contexte').first().json.workflowId;\nconst attempt = $('Initialiser contexte').first().json.attempt;\nreturn [{ json: {\n  workflowId,\n  attempt,\n  diagnosis: parsed.diagnosis,\n  fix: parsed.fix,\n  putBody: {\n    name: parsed.workflow.name,\n    nodes: parsed.workflow.nodes,\n    connections: parsed.workflow.connections,\n    settings: {\n      executionOrder: 'v1',\n      errorWorkflow: 'YOUR_N8N_URL/workflow/RaHgXr2IpKEIfpw1'\n    }\n  }\n}}];"
      },
