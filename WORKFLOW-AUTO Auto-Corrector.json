        "jsCode": "const body = $input.first().json.body;\nreturn [{ json: {\n  workflowId: body.workflowId,\n  errorMessage: body.errorMessage,\n  nodeName: body.nodeName || 'inconnu',\n  attempt: body.attempt || 1,\n  maxAttempts: 3\n}}];"
