    {
      "parameters": {
        "jsCode": "const executions = $input.first().json.data || [];\nconst workflowId = $('Parser correction').first().json.workflowId;\nconst attempt = $('Parser correction').first().json.attempt;\n\nif (executions.length === 0) {\n  return [{ json: { stillFailing: false, workflowId, attempt } }];\n}\n\nconst lastExec = executions[0];\nconst execTime = new Date(lastExec.startedAt).getTime();\nconst now = Date.now();\nconst isRecent = (now - execTime) < 30000;\n\nif (isRecent && lastExec.status === 'error') {\n  return [{ json: {\n    stillFailing: true,\n    workflowId,\n    attempt: attempt + 1,\n    errorMessage: lastExec.data?.resultData?.error?.message || 'Erreur inconnue',\n    nodeName: lastExec.data?.resultData?.lastNodeExecuted || 'inconnu'\n  }}];\n}\n\nreturn [{ json: { stillFailing: false, workflowId, attempt } }];"
      },
