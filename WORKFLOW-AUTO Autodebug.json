    {
      "parameters": {
        "jsCode": "const err = $input.first().json;\nreturn [{ json: {\n  workflowId: String(err.workflow?.id || ''),\n  workflowName: err.workflow?.name || 'Unknown',\n  nodeName: err.execution?.lastNodeExecuted || 'Unknown',\n  errorMessage: err.execution?.error?.message || err.error?.message || 'Unknown error',\n  errorStack: (err.execution?.error?.stack || err.error?.stack || '').slice(0, 500),\n  executionId: err.execution?.id || ''\n}}];"
      },
      "id": "a2e54779-c228-4d6f-bac9-45161ccb3c48",
      "name": "Extraire infos erreur",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        -16
      ]
    },
    {
      "parameters": {
