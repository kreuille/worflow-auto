      "id": "059e4162-ec04-4afd-895b-5b63c98dea87",
      "name": "Recuperer workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        -16
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "YOUR_ANTHROPIC_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 8192,\n  \"temperature\": 0,\n  \"system\": \"Tu es un expert n8n en mode debug automatique.\\n\\nOn te donne un workflow n8n qui a planté, le nom du node fautif et le message d'erreur.\\n\\nTon travail : analyser l'erreur, corriger le workflow, retourner le workflow complet corrigé.\\n\\nRéponds UNIQUEMENT en JSON :\\n{\\n  \\\"diagnosis\\\": \\\"Cause de l'erreur en 1 phrase\\\",\\n  \\\"fix\\\": \\\"Ce qui a été corrigé en 1 phrase\\\",\\n  \\\"workflow\\\": { ... workflow n8n complet corrigé ... }\\n}\\n\\nNe mets JAMAIS de texte hors du JSON.\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Workflow : {{ $('Extraire infos erreur').first().json.workflowName }}\\nNode fautif : {{ $('Extraire infos erreur').first().json.nodeName }}\\nErreur : {{ $('Extraire infos erreur').first().json.errorMessage }}\\n\\nJSON du workflow :\\n{{ JSON.stringify($input.first().json).slice(0, 40000) }}\"\n  }]\n}",
        "options": {}
      },
      "id": "c088a575-fee4-448b-b021-99d6bff4a74b",
      "name": "Claude analyse et corrige",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        928,
        -16
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text.trim();\nlet parsed;\ntry {\n  let cleaned = raw.replace(/```json\\n?/gi,'').replace(/```\\n?/gi,'').trim();\n  let depth = 0, start = -1, end = -1;\n  for (let i = 0; i < cleaned.length; i++) {\n    if (cleaned[i] === '{') { if (depth === 0) start = i; depth++; }\n    else if (cleaned[i] === '}') { depth--; if (depth === 0) { end = i; break; } }\n  }\n  if (start === -1 || end === -1) throw new Error('No valid JSON object found');\n  parsed = JSON.parse(cleaned.substring(start, end + 1));\n} catch(err) {\n  return [{ json: { success: false, error: err.message } }];\n}\nreturn [{ json: { diagnosis: parsed.diagnosis, fix: parsed.fix, workflowJson: parsed.workflow, isValid: !!parsed.workflow } }];"
      },
      "id": "a7e351c8-1dc9-411c-aab3-9650d158f196",
      "name": "Parser reponse Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
