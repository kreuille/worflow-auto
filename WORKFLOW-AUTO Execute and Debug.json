      "id": "d82c557d-ada0-4872-8e10-197bea359294",
      "name": "Get derniere execution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        208,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "const executions = $input.first().json.data || [];\nconst workflowId = $('Webhook get error').first().json.query.workflowId;\n\nif(executions.length === 0) {\n  return [{ json: { status: 'no_execution', hasError: false, workflowId } }];\n}\n\nconst last = executions[0];\n\nif(last.status === 'running') {\n  return [{ json: { status: 'running', hasError: false, workflowId, executionId: last.id } }];\n}\n\nif(last.status === 'error') {\n  const errorMsg = last.data?.resultData?.error?.message\n    || last.data?.resultData?.error?.description\n    || 'Erreur inconnue';\n  const nodeName = last.data?.resultData?.lastNodeExecuted || 'inconnu';\n  return [{ json: { status: 'error', hasError: true, workflowId, errorMessage: errorMsg, nodeName, executionId: last.id } }];\n}\n\nreturn [{ json: { status: last.status, hasError: false, workflowId, executionId: last.id } }];"
      },
      "id": "562b08a1-3963-41bb-9038-74c2e5d503a3",
      "name": "Analyser execution",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        256
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
