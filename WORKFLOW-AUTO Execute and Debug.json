      "typeVersion": 4.2,
      "position": [
        800,
        192
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "YOUR_ANTHROPIC_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 8192,\n  \"temperature\": 0,\n  \"system\": \"Tu es un expert n8n en mode debug. On te donne un workflow n8n existant et un message d'erreur.\\n\\nTon travail : analyser l'erreur, identifier le node fautif, corriger le workflow.\\n\\nRéponds TOUJOURS en JSON avec ce format exact :\\n{\\n  \\\"diagnosis\\\": \\\"Explication de l'erreur en 1-2 phrases\\\",\\n  \\\"fix\\\": \\\"Description de la correction appliquée\\\",\\n  \\\"workflow\\\": { ... le workflow n8n corrigé complet ... }\\n}\\n\\nNe mets JAMAIS de texte hors du JSON.\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Node fautif : {{ $('Analyser execution').first().json.nodeName }}\\nErreur : {{ $('Analyser execution').first().json.errorMessage }}\\n\\nWorkflow actuel :\\n{{ JSON.stringify($json) }}\"\n  }]\n}",
        "options": {}
      },
      "id": "2bcc321d-a6b7-43fc-bda3-941e4a8208a1",
      "name": "Claude debug auto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1008,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text.trim();\nlet parsed;\ntry {\n  let cleaned = raw.replace(/```json\\n?/gi,'').replace(/```\\n?/gi,'').trim();\n  let depth = 0, start = -1, end = -1;\n  for (let i = 0; i < cleaned.length; i++) {\n    if (cleaned[i] === '{') { if (depth === 0) start = i; depth++; }\n    else if (cleaned[i] === '}') { depth--; if (depth === 0) { end = i; break; } }\n  }\n  if (start === -1 || end === -1) throw new Error('No valid JSON object found');\n  parsed = JSON.parse(cleaned.substring(start, end + 1));\n} catch(err) {\n  return [{ json: { success: false, error: err.message } }];\n}\nconst workflowId = $('Analyser execution').first().json.workflowId;\nreturn [{ json: {\n  workflowId,\n  diagnosis: parsed.diagnosis,\n  fix: parsed.fix,\n  putBody: {\n    name: parsed.workflow.name,\n    nodes: parsed.workflow.nodes,\n    connections: parsed.workflow.connections,\n    settings: { executionOrder: 'v1', errorWorkflow: 'YOUR_N8N_URL/workflow/RaHgXr2IpKEIfpw1' }\n  }\n}}];"
      },
